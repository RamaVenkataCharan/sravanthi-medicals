# Backend Environment Configuration
# Copy this file to backend/.env and fill in your values

# ── Supabase ───────────────────────────────────────────────────────
# Use the SERVICE ROLE key (not anon key) for write operations
# Found at: Supabase Dashboard > Project Settings > API > Service Role Key
SUPABASE_URL=https://ufamxbaocwwhecmaewrp.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Alternatively, the anon key works for public tables with RLS disabled:
# SUPABASE_URL=https://ufamxbaocwwhecmaewrp.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── FastAPI ────────────────────────────────────────────────────────
# Port for the search API (default 8000)
API_PORT=8000
